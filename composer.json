{
    "name": "philicevic/faceit-php",
    "description": "A PHP SDK for FACEITs api.",
    "version": "0.1.1",
    "type": "library",
    "require": {
        "php": "^8.3",
        "saloonphp/saloon": "^4.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Philicevic\\FaceitPhp\\": "src/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Philipp Ehrenberg",
            "email": "ehrenberg.ph@gmail.com"
        }
    ],
    "require-dev": {
        "pestphp/pest": "^4.4",
        "symfony/var-dumper": "^7.4",
        "laravel/pint": "^1.29"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
